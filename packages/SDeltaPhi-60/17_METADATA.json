    "subject_splitting": "BenefitSubject != CostSubject",
    "aggregate_masking": "TotalBenefit - VisibleIndividualCost",
    "sacrifice_capture": "GreaterGoodClaim + NonConsensualCostTransfer",
    "irreversible_minor_cost": "SmallAggregateCostClaim + HighIrreversibilityForMinority",
    "repair_burden_shift": "PolicyBenefit -> Aggregate ; RepairCost -> HarmedSubject",
    "consent_failure": "CostImposition - RefusalPath - ExitPath",
    "incomplete_utility": "AggregateBenefit - RepairAttribution",
    "responsible_utility": "AggregateBenefit + CostAttribution + RepairPath + Reentry"
